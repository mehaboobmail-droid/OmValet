{
  "rules": {
    ".read": false,
    ".write": false,

    "cars": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "history": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "activity": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": false
      }
    },
    "valets": {
      ".read": "auth != null",
      "$uid": {
        ".write": "root.child('admins').child(auth.uid).val() === true"
      }
    },
    "meta": {
      ".read": "auth != null",
      "ticketCounter": {
        ".write": "auth != null"
      },
      "checkedOutCount": {
        ".write": "auth != null"
      },
      "slotConfig": {
        ".write": "root.child('admins').child(auth.uid).val() === true"
      }
    },
    "shiftTypes": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).val() === true"
    },
    "shifts": {
      ".read": "auth != null",
      ".write": "root.child('admins').child(auth.uid).val() === true"
    }
  }
}
