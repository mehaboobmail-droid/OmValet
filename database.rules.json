{
  "rules": {
    ".read": false,
    ".write": false,

    "cars": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())"
    },
    "history": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())"
    },
    "activity": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())"
    },
    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "valets": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "meta": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      "ticketCounter": {
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())"
      },
      "checkedOutCount": {
        ".write": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())"
      },
      "slotConfig": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "shiftTypes": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    },
    "shifts": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).val() === true || root.child('valets').child(auth.uid).exists())",
      ".write": "auth != null && root.child('admins').child(auth.uid).val() === true"
    }
  }
}
